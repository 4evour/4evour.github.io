---
import { Icon } from "astro-icon/components";

const links = [
  { href: "/", label: "首页" },
  { href: "/blog/", label: "文章" },
  { href: "/tags/", label: "标签" },
  { href: "/projects/", label: "项目" },
  { href: "/about/", label: "关于" },
];
---

<header class="site-header">
  <nav class="container nav" aria-label="主导航">
    <a class="brand" href="/" aria-label="4evour 首页">
      <span class="brand-mark">4e</span>
      <span>4evour blog</span>
    </a>
    <div class="nav-links">
      {links.map((link) => <a href={link.href}>{link.label}</a>)}
      <a class="icon-link" href="/search/" aria-label="搜索">
        <Icon name="lucide:search" aria-hidden="true" />
      </a>
      <a class="icon-link" href="/rss.xml" aria-label="RSS 订阅">
        <Icon name="lucide:rss" aria-hidden="true" />
      </a>
      <button class="theme-toggle" type="button" aria-label="切换明暗主题" data-theme-toggle>
        <Icon class="theme-icon theme-icon-light" name="lucide:sun" aria-hidden="true" />
        <Icon class="theme-icon theme-icon-dark" name="lucide:moon" aria-hidden="true" />
      </button>
    </div>
  </nav>
</header>
