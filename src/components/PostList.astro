---
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../utils/posts";

interface Props {
  posts: CollectionEntry<"blog">[];
  variant?: "list" | "cards";
}

const { posts, variant = "list" } = Astro.props;
---

<ul class:list={["post-list", variant === "cards" && "post-list-cards"]}>
  {
    posts.map((post) => (
      <li class="post-item">
        <a href={`/blog/${post.id}/`}>
          {variant === "cards" && (
            <div class={`post-cover tone-${post.data.coverTone}`} aria-hidden="true">
              <span>{post.data.coverLabel ?? post.data.tags[0] ?? "Note"}</span>
            </div>
          )}
          <div>
            <h3>{post.data.title}</h3>
            <p>{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="tag-list" aria-label="文章标签">
                {post.data.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <time class="post-meta" datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
        </a>
      </li>
    ))
  }
</ul>
