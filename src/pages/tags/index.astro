---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTags, getPublishedPosts } from "../../utils/posts";

const posts = await getPublishedPosts();
const tags = getAllTags(posts);
---

<BaseLayout title="标签" description="4evour 博客的文章标签。">
  <section class="container page-title">
    <p class="eyebrow">Tags</p>
    <h1>标签</h1>
    <p>用主题把文章串起来。</p>
  </section>
  <section class="container section">
    <div class="tag-list">
      {tags.map((tag) => <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>{tag}</a>)}
    </div>
  </section>
</BaseLayout>
