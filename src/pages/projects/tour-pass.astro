---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";
import { getPostsByProject, getPublishedPosts } from "../../utils/posts";

const projectName = "Tour Pass";
const posts = getPostsByProject(await getPublishedPosts(), projectName);
---

<BaseLayout title={projectName} description="Tour Pass 项目文章归档。">
  <section class="container project-detail-hero">
    <div>
      <p class="eyebrow">Project archive</p>
      <h1>{projectName}</h1>
      <p>
        一个 C++17 + Python Agent 双引擎城市自由行规划项目，把 POI 图、Dijkstra/A*、Beam Search、BM25、
        LangGraph 多 Agent、21 城市真实 POI、React 行程编辑器和 Render/Docker 部署串成可演示系统。
      </p>
    </div>
    <div class="project-detail-panel" aria-label="项目技术栈">
      <span>C++17</span>
      <span>LangGraph</span>
      <span>React</span>
      <span>Render</span>
    </div>
  </section>

  <section class="container evidence-strip">
    <div class="evidence-grid">
      <article>
        <span>Data</span>
        <strong>21 城市 / 15000+ POI</strong>
        <p>多城市数据集覆盖景点、餐饮、酒店、交通和夜游；每城配套 guidebook 与 1000-2000 条通勤边。</p>
      </article>
      <article>
        <span>Engine</span>
        <strong>C++ + Python Agent</strong>
        <p>C++ 负责可解释规划与服务运行时，Python Agent 负责自然语言、RAG、酒店锚点、聚类和生成编排。</p>
      </article>
      <article>
        <span>Runtime</span>
        <strong>Render + smoke</strong>
        <p>线上 Demo 已部署，Docker smoke 把 `/agent/health` 纳入硬门禁，避免主服务可用但 Agent 不通。</p>
      </article>
    </div>
  </section>

  <section class="container section project-video-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Demo</p>
        <h2>Web 演示与线上入口</h2>
        <p>浏览器演示展示候选对比、路线明细、算法解释、路径检索和模板兜底；最新版本还提供 Render 线上演示。</p>
      </div>
      <a class="button" href="https://tour-pass.onrender.com" rel="noreferrer">打开线上演示</a>
    </div>
    <video controls preload="metadata" poster="/videos/tour-pass/tour-pass-web-demo-poster.jpg" aria-label="Tour Pass Web 演示视频">
      <source src="/videos/tour-pass/tour-pass-web-demo.mp4" type="video/mp4" />
      你的浏览器不支持 HTML5 视频播放，可以直接访问 /videos/tour-pass/tour-pass-web-demo.mp4。
    </video>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Notes</p>
        <h2>项目文章</h2>
        <p>按架构、算法、工程化、真实数据和 AI Agent 平台化更新拆开写，方便看清这个项目从 C++ 服务到双引擎系统的演进。</p>
      </div>
      <a class="button" href="/projects/">返回项目</a>
    </div>
    <PostList posts={posts} variant="cards" />
  </section>
</BaseLayout>
