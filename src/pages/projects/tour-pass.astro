---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";
import { getPostsByProject, getPublishedPosts } from "../../utils/posts";

const projectName = "Tour Pass";
const posts = getPostsByProject(await getPublishedPosts(), projectName);
---

<BaseLayout title={projectName} description="Tour Pass 项目文章归档。">
  <section class="container project-detail-hero">
    <div>
      <p class="eyebrow">Project archive</p>
      <h1>{projectName}</h1>
      <p>
        一个 C++17 城市自由行行程规划算法服务，把 POI 图、Dijkstra/A*、
        Beam Search、BM25 检索、候选对比、服务运行时、真实 POI 流水线和 LLM/模板解释串成可离线演示的本地系统。
      </p>
    </div>
    <div class="project-detail-panel" aria-label="项目技术栈">
      <span>C++17</span>
      <span>Beam Search</span>
      <span>Real POI</span>
      <span>Docker</span>
    </div>
  </section>

  <section class="container evidence-strip">
    <div class="evidence-grid">
      <article>
        <span>Data</span>
        <strong>500 POI / 1937 edges</strong>
        <p>本机高德流水线跑通长沙真实 POI，边来源保留 amap 与 geo_estimated 标记。</p>
      </article>
      <article>
        <span>Trust</span>
        <strong>98.5% AMap edges</strong>
        <p>估算边重试后仍披露剩余 29 条估算边，不把真实 POI 包装成实时路网。</p>
      </article>
      <article>
        <span>Runtime</span>
        <strong>Docker + smoke</strong>
        <p>容器默认关闭远程 LLM，配合 API/UI 冒烟和本地性能报告支撑演示复现。</p>
      </article>
    </div>
  </section>

  <section class="container section project-video-section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Demo</p>
        <h2>Web 演示视频</h2>
        <p>约 5 分钟浏览器演示，展示候选对比、路线明细、算法解释、路径检索和模板兜底。</p>
      </div>
      <a class="button" href="/blog/tour-pass-real-data-demo/">阅读更新记录</a>
    </div>
    <video controls preload="metadata" poster="/videos/tour-pass/tour-pass-web-demo-poster.jpg" aria-label="Tour Pass Web 演示视频">
      <source src="/videos/tour-pass/tour-pass-web-demo.mp4" type="video/mp4" />
      你的浏览器不支持 HTML5 视频播放，可以直接访问 /videos/tour-pass/tour-pass-web-demo.mp4。
    </video>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Notes</p>
        <h2>项目文章</h2>
        <p>按架构、算法、工程化和真实数据演示四条线拆开写，方便看清这个项目从数据、算法到运行时治理和演示证据的完整链路。</p>
      </div>
      <a class="button" href="/projects/">返回项目</a>
    </div>
    <PostList posts={posts} variant="cards" />
  </section>
</BaseLayout>
