---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostList from "../../components/PostList.astro";
import TechForceGraph from "../../components/TechForceGraph.astro";
import { getPostsByProject, getPublishedPosts } from "../../utils/posts";

const projectName = "灵山胜境智能导览系统";
const posts = getPostsByProject(await getPublishedPosts(), projectName);
---

<BaseLayout title={projectName} description="灵山胜境智能导览系统项目文章归档。">
  <section class="container project-detail-hero">
    <div>
      <p class="eyebrow">Project archive</p>
      <h1>{projectName}</h1>
      <p>
        这是我把 Go/Gin、PostgreSQL/GORM、Vue、RAG 知识库、Docker 复现、OpenAI 兼容接口、数据看板和 Live2D
        数字人串到一起的一次项目实践。最新口径加入了真实资料评估集和数字人联调检查，不把合成闭集指标包装成线上结果。
      </p>
    </div>
    <div class="project-detail-panel" aria-label="项目技术栈">
      <span>Go / Gin</span>
      <span>Vue</span>
      <span>RAG</span>
      <span>PostgreSQL</span>
    </div>
  </section>

  <section class="container section evidence-strip" aria-label="项目可信度证据">
    <div class="section-head">
      <div>
        <p class="eyebrow">Evidence</p>
        <h2>可复现证据</h2>
        <p>项目现在把运行、评估和联调边界写成了可复现文档，避免只靠截图讲故事。</p>
      </div>
    </div>
    <div class="evidence-grid">
      <article>
        <span>RAG real eval</span>
        <strong>122 切片 / 203 问答</strong>
        <p>真实资料 retrieval-only bench：Recall@8 85.5%、MRR@8 0.749、关键词覆盖率 94.3%，不包含生成、ASR 或 TTS。</p>
      </article>
      <article>
        <span>Docker reproduce</span>
        <strong>PostgreSQL 主路径</strong>
        <p>通过 Docker Compose 启动 PostgreSQL 16 和 Go 服务；无外部 AI Key 时仍可跑页面和 BM25/词面检索评估。</p>
      </article>
      <article>
        <span>VTuber integration</span>
        <strong>协议适配清单</strong>
        <p>数字人部分明确验证 OpenAI 兼容接口、SSE、WebSocket、打断/重连、麦克风权限和 trace 状态展示。</p>
      </article>
    </div>
  </section>

  <section class="container section demo-video-section" aria-label="项目演示视频">
    <div class="section-head">
      <div>
        <p class="eyebrow">Demo video</p>
        <h2>本地演示视频</h2>
        <p>视频串起游客端、数据看板、管理后台、地图、数字人导览和 RAG 评估边界，展示这套系统的实际运行路径。</p>
      </div>
    </div>
    <figure class="demo-video">
      <video controls preload="metadata" poster="/images/blog/scenic-guide/home.png">
        <source src="/videos/lingshan-demo-subtitled.mp4" type="video/mp4" />
        你的浏览器暂不支持直接播放该演示视频。
      </video>
      <figcaption>录制于本地演示环境，使用 demo seed 数据，不代表公网商业系统。</figcaption>
    </figure>
  </section>

  <section class="container section proof-strip" aria-label="项目真实页面截图">
    <div class="section-head">
      <div>
        <p class="eyebrow">Runtime proof</p>
        <h2>真实页面截图</h2>
        <p>这些截图来自最新代码本地启动后的灵山导览系统，覆盖游客端、数据大屏、地图、管理后台和 Live2D 数字人舞台。</p>
      </div>
    </div>
    <div class="proof-grid">
      <figure>
        <img src="/images/blog/scenic-guide/home.png" alt="灵山智能导览游客端首页截图" loading="lazy" />
        <figcaption>游客端首页</figcaption>
      </figure>
      <figure>
        <img src="/images/blog/scenic-guide/dashboard.png" alt="灵山智能导览数据大屏截图" loading="lazy" />
        <figcaption>运营数据大屏</figcaption>
      </figure>
      <figure>
        <img src="/images/blog/scenic-guide/map.png" alt="灵山智能导览游客地图截图" loading="lazy" />
        <figcaption>游客实时地图</figcaption>
      </figure>
      <figure>
        <img src="/images/blog/scenic-guide/admin.png" alt="灵山智能导览管理后台知识库截图" loading="lazy" />
        <figcaption>知识库管理后台</figcaption>
      </figure>
      <figure>
        <img src="/images/blog/scenic-guide/digital-human.png" alt="灵山智能导览 Live2D 数字人舞台截图" loading="lazy" />
        <figcaption>Live2D 数字人舞台</figcaption>
      </figure>
    </div>
  </section>

  <TechForceGraph />

  <section class="container section">
    <div class="section-head">
      <div>
        <p class="eyebrow">Notes</p>
        <h2>项目文章</h2>
        <p>按技术链路拆开写，比单独放一个仓库链接更容易看清这个项目做了什么。</p>
      </div>
      <a class="button" href="/projects/">返回项目</a>
    </div>
    <PostList posts={posts} variant="cards" />
  </section>
</BaseLayout>
