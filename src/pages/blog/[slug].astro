---
import { render } from "astro:content";
import BackToTop from "../../components/BackToTop.astro";
import Giscus from "../../components/Giscus.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReadingProgress from "../../components/ReadingProgress.astro";
import SeriesNav from "../../components/SeriesNav.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import { getPublishedPosts, getSeriesPosts, formatDate } from "../../utils/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const ogImage = new URL(`/og/${post.id}.png`, Astro.site).href;

const allPosts = await getPublishedPosts();
const seriesPosts = post.data.project
  ? getSeriesPosts(allPosts, post.data.project)
  : [];
const currentIndex = seriesPosts.findIndex((p) => p.id === post.id);
const prev = currentIndex > 0 ? seriesPosts[currentIndex - 1] : null;
const next = currentIndex >= 0 && currentIndex < seriesPosts.length - 1
  ? seriesPosts[currentIndex + 1]
  : null;
---

<BaseLayout title={post.data.title} description={post.data.description} ogImage={ogImage} ogType="article">
  <ReadingProgress />
  <article class="article">
    <header class="article-header article-hero">
      <div>
        <p class="eyebrow">{post.data.project ?? "Post"}</p>
        <h1>{post.data.title}</h1>
        <p>{post.data.description}</p>
        <div class="post-meta">
          <time datetime={post.data.pubDate.toISOString()}>
            {formatDate(post.data.pubDate)}
          </time>
          {
            post.data.tags.map((tag) => (
              <a class="tag" href={`/tags/${encodeURIComponent(tag)}/`}>
                {tag}
              </a>
            ))
          }
        </div>
      </div>
      <div class={`post-cover article-cover tone-${post.data.coverTone}`} aria-hidden="true">
        <span>{post.data.coverLabel ?? post.data.tags[0] ?? "Note"}</span>
      </div>
    </header>
    <div class="article-layout">
      <TableOfContents headings={headings} />
      <div class="article-body">
        <Content />
      </div>
    </div>
  </article>
  {seriesPosts.length > 1 && (prev || next) && (
    <SeriesNav prev={prev} next={next} project={post.data.project!} />
  )}
  <Giscus />
  <BackToTop />
</BaseLayout>
