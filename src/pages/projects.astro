---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="项目" description="4evour 的项目与作品。">
  <section class="container page-title">
    <p class="eyebrow">Projects</p>
    <h1>项目</h1>
    <p>后续可以在这里展示开源项目、实验作品或学习成果。</p>
  </section>
  <section class="container section">
    <ul class="post-list">
      <li class="post-item">
        <a href="https://github.com/4evour" rel="noreferrer">
          <div>
            <h3>GitHub</h3>
            <p>先从 GitHub 入口开始，后续再补充精选项目。</p>
          </div>
          <span class="post-meta">外部链接</span>
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>
