---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPostsByProject, getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
const scenicGuideName = "灵山胜境智能导览系统";
const scenicGuidePosts = getPostsByProject(posts, scenicGuideName);
const tourPassName = "Tour Pass";
const tourPassPosts = getPostsByProject(posts, tourPassName);
---

<BaseLayout title="项目" description="4evour 的项目与作品。">
  <section class="container page-title project-index-title">
    <div>
      <p class="eyebrow">Projects</p>
      <h1>项目</h1>
      <p>把做过的项目整理成可以继续阅读的入口，而不只是放几个仓库链接。</p>
    </div>
      <div class="project-index-mark" aria-hidden="true">02</div>
  </section>
  <section class="container section">
    <a class="project-card" href="/projects/scenic-guide/">
      <div class="project-card-visual" aria-hidden="true">
        <span>Guide</span>
      </div>
      <div>
        <p class="eyebrow">Case study</p>
        <h2>{scenicGuideName}</h2>
        <p>
          一个 Go + Vue + RAG + Live2D 的景区智能导览系统，包含问答、知识库、
          管理后台、数据看板和数字人交互链路。
        </p>
        <div class="tag-list">
          <span class="tag">Go</span>
          <span class="tag">Vue</span>
          <span class="tag">RAG</span>
          <span class="tag">Live2D</span>
        </div>
      </div>
      <span class="post-meta">{scenicGuidePosts.length} 篇文章</span>
    </a>

    <a class="project-card project-card-tour" href="/projects/tour-pass/">
      <div class="project-card-visual" aria-hidden="true">
        <span>Tour</span>
      </div>
      <div>
        <p class="eyebrow">Case study</p>
        <h2>{tourPassName}</h2>
        <p>
          一个 C++17 城市自由行行程规划算法服务，覆盖 POI 图建模、最短路、
          Beam Search、候选对比、BM25 检索和本地 Web 演示台。
        </p>
        <div class="tag-list">
          <span class="tag">C++</span>
          <span class="tag">算法</span>
          <span class="tag">Beam Search</span>
          <span class="tag">BM25</span>
        </div>
      </div>
      <span class="post-meta">{tourPassPosts.length} 篇文章</span>
    </a>
  </section>
</BaseLayout>
